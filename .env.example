# ============ 服务端口 ============
# HTTP 服务监听端口（与 docker run -p 或 compose ports 对应即可，容器内默认 8000）
PORT=8000

# ============ 项目/运行环境 ============
# 项目类型：workflow | agent
COZE_PROJECT_TYPE=agent
# 运行环境：DEV（开发，可能开启 reload）| PROD（生产）
COZE_PROJECT_ENV=PROD
# 工作目录（容器内一般为 /app，可不设）
# COZE_WORKSPACE_PATH=/app

# ============ 日志 ============
LOG_LEVEL=INFO
# COZE_LOG_DIR=/tmp/app/work/logs/bypass

# ============ 数据库（使用知识库/数据库时必填）============
# PostgreSQL 连接 URL
# PGDATABASE_URL=postgresql://user:password@host:5432/dbname

# ============ 对象存储 S3（使用 S3 时填写）============
# COZE_BUCKET_ENDPOINT_URL=
# COZE_BUCKET_NAME=

# ============ Coze 集成（Agent 调用模型/外部 API 时填写）============
# COZE_WORKLOAD_IDENTITY_API_KEY=
# COZE_INTEGRATION_MODEL_BASE_URL=
# COZE_INTEGRATION_BASE_URL=

# ============ Coze Loop / 追踪（可选）============
# COZE_PROJECT_SPACE_ID=
# COZE_LOOP_API_TOKEN=
# COZE_LOOP_BASE_URL=https://api.coze.cn
# COZE_PROJECT_ID=
# COZE_PROJECT_COMMIT_HASH=
